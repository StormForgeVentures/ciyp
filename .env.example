# ciyp-platform — local development environment
# Copy to .env and fill in the secrets. .env is gitignored; this template is not.
# Values marked [local default] are the well-known Supabase local-dev demo keys —
# safe to commit, never valid outside `supabase start`.

# ── Supabase (local stack — `supabase start`; ports 553xx, see supabase/config.toml) ──
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0  # [local default]
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU  # [local default] server-side only
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres  # [local default] migrations + seed
SEED_ADMIN_PASSWORD=ciyp-dev-admin-2026  # [local default] admin-console fixture password (seed:identities + Playwright)
# apps/api verifies session JWTs against the Supabase JWKS (ES256) at SUPABASE_URL — no secret needed.

# ── AI providers (ADR-007 ratified stack — keys held platform-side, never per-tenant) ──
OPENROUTER_API_KEY=            # LLM gateway — all model slots route through OpenRouter
VOYAGE_API_KEY=                # embeddings + rerank (voyage-3-large / rerank-2) — seed prerequisite
DEEPGRAM_API_KEY=              # streaming STT (apps/voice)
FISH_AUDIO_API_KEY=            # TTS — per-tenant voice_id lives in app_config, key is platform-side

# ── Stripe (test mode — platform account; flow (b) wallet top-ups only, ADR-008) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Program-access store connector vault: AES-256-GCM DEK that encrypts each coach's Stripe
# credentials at rest. MUST be base64-encoded 32 bytes; validated fail-loud at boot (M-1).
# Generate a real one per environment with:  openssl rand -base64 32
CONNECTOR_VAULT_KEY=oB56qk9v3m9E9pRm0DvLKbTYXOrKL3zlkG6sOUQcevw=  # [local default] dev-only throwaway; never valid in prod

# ── GitHub Packages (consumed by .npmrc — needed for @theamazingwolf/sport-* installs) ──
# Classic PAT with read:packages covering BOTH orgs (theamazingwolf + StormForgeVentures).
# Usually exported in your shell profile rather than .env; listed here for completeness.
NODE_AUTH_TOKEN=

# ── apps/api runtime ──
PORT=8787
API_ALLOWED_ORIGIN=http://127.0.0.1:5173  # coach console dev origin (CORS allowlist)

# ── apps/web (Vite — only VITE_-prefixed vars reach the browser bundle) ──
VITE_SUPABASE_URL=http://127.0.0.1:55321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0  # [local default]
VITE_API_BASE_URL=http://127.0.0.1:8787
