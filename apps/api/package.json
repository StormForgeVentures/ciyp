{
  "name": "@ciyp/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CIYP engine — Hono AI execution runtime (Sport), eval harness, admin API, wallet, connectors, provisioning. Scaffold in PRD-001a; runtime lands PRD-002+.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ciyp/agents": "workspace:*",
    "@ciyp/prompts": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@stormforgeventures/ciyp-shared": "workspace:*",
    "@supabase/supabase-js": "^2.110.0",
    "@theamazingwolf/sport-core": "^0.5.3",
    "@theamazingwolf/sport-server": "^0.5.3",
    "hono": "^4.6.13",
    "pg": "^8.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^9.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vitest": "^2.1.8"
  }
}
