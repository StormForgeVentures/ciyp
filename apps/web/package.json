{
  "name": "@ciyp/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CIYP coach/admin console — Vite + React + TanStack. Coach/admin ONLY (decision #11: member web = template PWA). Shell scaffold in PRD-001a; the console lands in PRD-006a.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "e2e": "playwright test",
    "lint": "eslint ."
  },
  "dependencies": {
    "@stormforgeventures/ciyp-shared": "workspace:*",
    "@stormforgeventures/ciyp-ui-tokens": "workspace:*",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.170.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.12",
    "dotenv": "^17.4.2",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
